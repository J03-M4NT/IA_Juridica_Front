rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Regla para las fotos de perfil
    match /profile-photos/{userId}/{fileName} {
      // Permitir lectura a cualquier usuario autenticado
      allow read: if request.auth != null;
      
      // Permitir escritura solo al propio usuario
      // Validar que sea una imagen y menor a 5MB
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Agregar aquí otras reglas para otros directorios según sea necesario
  }
}
